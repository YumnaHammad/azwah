# Admin portal credentials (change in production)
ADMIN_PASSWORD=azwah2026
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Required on Vercel for CRUD to persist ─────────────────────────────
# Create a free Upstash Redis database (Vercel Marketplace → Upstash Redis)
# or Vercel KV, then add these env vars in Vercel project settings:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV alternative names (auto-set if using Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Required on Vercel for image uploads ───────────────────────────────
# Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=
